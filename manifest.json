{
  "manifest_version": 3,
  "name": "Meet Bookmarks",
  "version": "1.1",
  "description": "Add bookmarked chat links to Google Meet",
  "permissions": ["storage"],
  "host_permissions": ["https://meet.google.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "48": "icon.png"
  }
}
